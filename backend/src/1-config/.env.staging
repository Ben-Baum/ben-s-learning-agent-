APP_ENV=staging

# ── Server ──────────────────────────────────────
PORT=8767

# ── LLM ─────────────────────────────────────────
LLM_PROVIDER=gemini
GOOGLE_API_KEY=REPLACE_WITH_STAGING_GOOGLE_API_KEY

# ── Auth ─────────────────────────────────────────
BEN_AGENT_SECRET=REPLACE_WITH_STAGING_SECRET

# ── Debug ────────────────────────────────────────
# Off in staging — mirrors production behavior
BEN_AGENT_DEBUG_ERRORS=0
AGENT_DEBUG_ERRORS=0

# ── Limits (production-like) ──────────────────────
BEN_AGENT_MAX_MESSAGE_CHARS=8000
BEN_AGENT_MAX_UPLOAD_BYTES=5242880
BEN_AGENT_MAX_FILES=8
BEN_AGENT_MAX_PDF_PAGES=40

# ── API key for Bridge API ────────────────────────
GENIE_API_KEY=REPLACE_WITH_STAGING_GENIE_KEY
