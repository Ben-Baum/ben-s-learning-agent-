APP_ENV=production

# ── Server ──────────────────────────────────────
# PORT is set by the hosting platform (Render etc.), do not hardcode here
# PORT=8766

# ── LLM ─────────────────────────────────────────
LLM_PROVIDER=gemini
GOOGLE_API_KEY=REPLACE_WITH_PRODUCTION_GOOGLE_API_KEY

# ── Auth ─────────────────────────────────────────
BEN_AGENT_SECRET=REPLACE_WITH_PRODUCTION_SECRET

# ── Debug ────────────────────────────────────────
BEN_AGENT_DEBUG_ERRORS=0
AGENT_DEBUG_ERRORS=0

# ── Limits ───────────────────────────────────────
BEN_AGENT_MAX_MESSAGE_CHARS=8000
BEN_AGENT_MAX_UPLOAD_BYTES=5242880
BEN_AGENT_MAX_FILES=8
BEN_AGENT_MAX_PDF_PAGES=40

# ── API key for Bridge API ────────────────────────
GENIE_API_KEY=REPLACE_WITH_PRODUCTION_GENIE_KEY
