# LLM: openai | gemini
LLM_PROVIDER=gemini

# OpenAI (when LLM_PROVIDER=openai)
OPENAI_API_KEY=replace_with_openai_key

# Gemini / Google AI Studio (used by the dashboard pipeline)
GOOGLE_API_KEY=replace_with_google_ai_studio_key

# API key for Bridge API (required)
GENIE_API_KEY=replace_with_local_bridge_key

# Optional: callback URL for run completion
# CALLBACK_URL=
