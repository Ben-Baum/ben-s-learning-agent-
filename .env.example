# LLM: openai | gemini
LLM_PROVIDER=openai

# OpenAI (when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Gemini (when LLM_PROVIDER=gemini) - stub; use OpenAI for MVP
GEMINI_API_KEY=

# API key for Bridge API (required)
GENIE_API_KEY=your-secret-api-key

# Optional: callback URL for run completion
# CALLBACK_URL=
